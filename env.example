# Copy to .env and fill in (run-web.sh loads .env automatically).
# OAuth redirect paths must match exactly what you register with each provider.

# Public URL of the app (no trailing slash). Required if you use a tunnel or non-default port.
# MUSIC_PUBLIC_ORIGIN=http://localhost:7070

# Spotify — https://developer.spotify.com/dashboard — redirect: $MUSIC_PUBLIC_ORIGIN/callback/spotify
SPOTIFY_CLIENT_ID=

# YouTube Data API — Google Cloud OAuth client (Desktop or Web). Redirect: $MUSIC_PUBLIC_ORIGIN/callback/youtube
# Scope used: youtube.readonly
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# SoundCloud — https://developers.soundcloud.com/ — redirect: $MUSIC_PUBLIC_ORIGIN/callback/soundcloud
SOUNDCLOUD_CLIENT_ID=
SOUNDCLOUD_CLIENT_SECRET=
